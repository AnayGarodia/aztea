# Core runtime
ENVIRONMENT= # development|production, default: development
API_KEY= # master API key, generate with: openssl rand -hex 32
DB_PATH= # path to SQLite file, default: ./registry.db
DATABASE_URL= # alternative to DB_PATH; accepts sqlite:///path or bare path; postgres:// noted but not yet supported
CORS_ALLOW_ORIGINS= # comma-separated allowed frontend origins, e.g. https://agentmarket.dev,https://www.agentmarket.dev (defaults to localhost dev ports when unset)
AGENTMARKET_FRONTEND_URL= # public URL of the frontend, used in 401 sign-up links, e.g. https://agentmarket.dev
# ── LLM providers (any single provider works — set key + optional base URL override) ──────────────

# Built-in providers (native SDKs)
GROQ_API_KEY=           # required for built-in agents default chain
OPENAI_API_KEY=         # GPT-4o, o1, gpt-image-1, etc.
ANTHROPIC_API_KEY=      # Claude 3/4 family (also aliased as "claude:")
COHERE_API_KEY=         # Command R+, Command A — uses native Cohere SDK

# AWS Bedrock (boto3 — supports Claude, Llama, Mistral, Titan, Nova via Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=      # optional, for temporary credentials
AWS_BEDROCK_REGION=     # default: us-east-1

# OpenAI-compatible providers — set KEY to enable, BASE_URL to override endpoint
XAI_API_KEY=            # Grok family (also aliased as "grok:")
XAI_BASE_URL=           # default: https://api.x.ai/v1
KIMI_API_KEY=           # Moonshot Kimi (also aliased as "kimi:")
KIMI_BASE_URL=          # default: https://api.moonshot.ai/v1
GEMINI_API_KEY=         # Google Gemini via OpenAI-compat (also aliased as "google:")
GEMINI_BASE_URL=        # default: https://generativelanguage.googleapis.com/v1beta/openai/
MISTRAL_API_KEY=        # Mistral Large, Codestral, etc.
MISTRAL_BASE_URL=       # default: https://api.mistral.ai/v1
TOGETHER_API_KEY=       # Together AI — 200+ open models
TOGETHER_BASE_URL=      # default: https://api.together.xyz/v1
FIREWORKS_API_KEY=      # Fireworks AI — fast open model inference
FIREWORKS_BASE_URL=     # default: https://api.fireworks.ai/inference/v1
DEEPSEEK_API_KEY=       # DeepSeek R1, V3
DEEPSEEK_BASE_URL=      # default: https://api.deepseek.com
PERPLEXITY_API_KEY=     # Perplexity Sonar models
PERPLEXITY_BASE_URL=    # default: https://api.perplexity.ai
CEREBRAS_API_KEY=       # Cerebras inference (ultra-fast Llama)
CEREBRAS_BASE_URL=      # default: https://api.cerebras.ai/v1
OPENROUTER_API_KEY=     # OpenRouter — unified access to 300+ models
OPENROUTER_BASE_URL=    # default: https://openrouter.ai/api/v1
SAMBANOVA_API_KEY=      # SambaNova Cloud — fast inference
SAMBANOVA_BASE_URL=     # default: https://api.sambanova.ai/v1
NOVITA_API_KEY=         # Novita AI — open model hosting
NOVITA_BASE_URL=        # default: https://api.novita.ai/v3/openai
AI21_API_KEY=           # AI21 Jamba models
AI21_BASE_URL=          # default: https://api.ai21.com/studio/v1
DEEPINFRA_API_KEY=      # DeepInfra serverless inference
DEEPINFRA_BASE_URL=     # default: https://api.deepinfra.com/v1/openai
HYPERBOLIC_API_KEY=     # Hyperbolic — fast open model inference
HYPERBOLIC_BASE_URL=    # default: https://api.hyperbolic.xyz/v1
ANYSCALE_API_KEY=       # Anyscale endpoints
ANYSCALE_BASE_URL=      # default: https://api.endpoints.anyscale.com/v1
OCTOAI_API_KEY=         # OctoAI text generation
OCTOAI_BASE_URL=        # default: https://text.octoai.run/v1
NVIDIA_API_KEY=         # NVIDIA NIM inference (also aliased as "nvidia:" or "nim:")
NVIDIA_BASE_URL=        # default: https://integrate.api.nvidia.com/v1
HUGGINGFACE_API_KEY=    # Hugging Face Inference API (also aliased as "hf:")
HUGGINGFACE_BASE_URL=   # default: https://api-inference.huggingface.co/v1
LEPTON_API_KEY=         # Lepton AI — set BASE_URL to your model endpoint
LEPTON_BASE_URL=        # e.g. https://llama3-1-70b.lepton.run/api/v1
PREDIBASE_API_KEY=      # Predibase fine-tuned models
PREDIBASE_BASE_URL=     # default: https://serving.app.predibase.com/v1
AZURE_OPENAI_API_KEY=   # Azure OpenAI — set BASE_URL to your resource endpoint
AZURE_OPENAI_BASE_URL=  # e.g. https://<resource>.openai.azure.com/openai/deployments/<deploy>

# Local inference (no key needed by default — set BASE_URL if using non-standard port)
OLLAMA_API_KEY=         # optional auth header for Ollama (default: none)
OLLAMA_BASE_URL=        # default: http://localhost:11434/v1
LMSTUDIO_API_KEY=       # optional
LMSTUDIO_BASE_URL=      # default: http://localhost:1234/v1

# Generic fallback — any OpenAI-compatible API not listed above
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=

# Dynamic provider auto-registration: for any unlisted provider set
#   {PROVIDER_NAME}_API_KEY + {PROVIDER_NAME}_BASE_URL  (e.g. MYMODEL_API_KEY, MYMODEL_BASE_URL)
# Then call it as "mymodel:model-name" anywhere a model spec is accepted.

OPENAI_IMAGE_MODEL=       # image model for built-in Image Generator Agent, default: gpt-image-1
OPENAI_IMAGE_QUALITY=     # image quality hint for OpenAI image generation, default: high
OPENAI_IMAGE_TIMEOUT_SECONDS= # timeout for OpenAI image generation requests, default: 120
AGENTMARKET_LLM_DEFAULT_CHAIN= # override fallback order, e.g. groq:llama-3.3-70b-versatile,openai:gpt-4o-mini,anthropic:claude-sonnet-4-6
REPLICATE_API_TOKEN= # required for built-in Video Storyboard Generator Agent (and optional image generation fallback)
REPLICATE_IMAGE_MODEL= # optional image model in owner/model or owner/model:version format
REPLICATE_VIDEO_MODEL= # required video model in owner/model or owner/model:version format
REPLICATE_TIMEOUT_SECONDS= # timeout for Replicate create+poll flow, default: 300
REPLICATE_POLL_INTERVAL_SECONDS= # Replicate polling interval, default: 2
PLATFORM_FEE_PCT= # default: 10
LOG_LEVEL= # default: INFO
SERVER_BASE_URL= # public base URL used for self-registration and proxy URLs, default: http://localhost:8000
FRONTEND_BASE_URL= # public URL of the frontend app for Stripe redirects (defaults to SERVER_BASE_URL)

# Stripe payments (optional — enables real card top-ups)
STRIPE_SECRET_KEY= # sk_live_... or sk_test_... from Stripe dashboard
STRIPE_WEBHOOK_SECRET= # whsec_... from Stripe dashboard > Webhooks (handles checkout.session.completed + account.updated)
STRIPE_PUBLISHABLE_KEY= # pk_live_... or pk_test_... (exposed to the frontend via /config/public)
TOPUP_DAILY_LIMIT_CENTS= # rolling 24h Stripe top-up cap per wallet, default: 100000 ($1,000.00); set 0 to disable
# Stripe Connect (agent withdrawals) uses the same STRIPE_SECRET_KEY — no extra keys needed.
# In the Stripe dashboard: enable Connect, add /stripe/webhook as a Connect webhook for "account.updated".

# Optional safety/feature toggles
ALLOW_PRIVATE_OUTBOUND_URLS= # allow private/localhost outbound agent URLs (0/1), default: 0
ADMIN_IP_ALLOWLIST= # optional admin CIDR/IP allowlist for /admin/* routes, e.g. 203.0.113.10,198.51.100.0/24
AGENTMARKET_ENABLE_LIVE_DISPUTE_JUDGES= # use Groq for dispute arbitration instead of fallback heuristics (0/1), default: 0
AGENTMARKET_ENABLE_LIVE_QUALITY_JUDGE= # use Groq for output quality judgment on completion (0/1), default: 0

# Jobs sweeper tuning
JOB_SWEEP_INTERVAL_SECONDS= # interval between sweep passes, default: 60
JOB_SWEEP_SLA_SECONDS= # age threshold for SLA timeout enforcement, default: 900
JOB_SWEEP_LIMIT= # max jobs processed per sweep category, default: 100
JOB_SWEEP_RETRY_DELAY_SECONDS= # retry delay for timeout-driven retries, default: 30

# Hook delivery worker tuning
HOOK_DELIVERY_INTERVAL_SECONDS= # poll interval for webhook delivery queue, default: 2
HOOK_DELIVERY_BATCH_SIZE= # deliveries claimed per worker pass, default: 50
HOOK_DELIVERY_MAX_ATTEMPTS= # max webhook retry attempts before dead-letter, default: 5
HOOK_DELIVERY_BASE_DELAY_SECONDS= # initial retry backoff for webhook failures, default: 5
HOOK_DELIVERY_MAX_DELAY_SECONDS= # max retry backoff for webhook failures, default: 300
HOOK_DELIVERY_CLAIM_LEASE_SECONDS= # lease duration when claiming delivery rows, default: 30

# Dispute and judge worker tuning
DISPUTE_FILE_WINDOW_SECONDS= # max age after completion to allow filing disputes, default: 604800
DEFAULT_JOB_DISPUTE_WINDOW_HOURS= # per-job dispute window when caller omits override, default: 72
DISPUTE_JUDGE_INTERVAL_SECONDS= # background arbitration loop interval (0 disables), default: 0

# Payments reconciliation worker tuning
PAYMENTS_RECONCILIATION_INTERVAL_SECONDS= # interval between automatic reconciliation runs (0 disables), default: 3600
PAYMENTS_RECONCILIATION_MAX_MISMATCHES= # max mismatches stored per reconciliation run, default: 100

# Built-in worker tuning
BUILTIN_JOB_WORKER_INTERVAL_SECONDS= # polling interval for built-in internal agents, default: 2
BUILTIN_JOB_WORKER_BATCH_SIZE= # batch size for built-in worker claims, default: 20

# SLO targets used by ops metrics endpoints
SLO_CLAIM_P95_TARGET_MS= # target p95 claim latency in milliseconds, default: 60000
SLO_SETTLEMENT_P95_TARGET_MS= # target p95 settlement latency in milliseconds, default: 300000
SLO_TIMEOUT_RATE_MAX= # target maximum timeout ratio, default: 0.05
SLO_HOOK_SUCCESS_RATE_MIN= # target minimum webhook success ratio, default: 0.95

# Optional MCP bridge script settings (scripts/agentmarket_mcp_server.py)
AGENTMARKET_BASE_URL= # registry API base URL for MCP bridge script, default: http://localhost:8000
AGENTMARKET_API_KEY= # API key used by MCP bridge script when invoking tools
AGENTMARKET_MCP_REFRESH_SECONDS= # MCP tool manifest refresh interval, default: 60
AGENTMARKET_MCP_TIMEOUT_SECONDS= # MCP HTTP timeout in seconds, default: 10
