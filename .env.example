# Core runtime
ENVIRONMENT= # development|production, default: development
API_KEY= # master API key, generate with: openssl rand -hex 32
DB_PATH= # path to SQLite file, default: ./registry.db
CORS_ALLOW_ORIGINS= # comma-separated allowed frontend origins, e.g. https://agentmarket.dev,https://www.agentmarket.dev (defaults to localhost dev ports when unset)
AGENTMARKET_FRONTEND_URL= # public URL of the frontend, used in 401 sign-up links, e.g. https://agentmarket.dev
GROQ_API_KEY= # optional: enables LLM dispute judges
PLATFORM_FEE_PCT= # default: 10
LOG_LEVEL= # default: INFO
SERVER_BASE_URL= # public base URL used for self-registration and proxy URLs, default: http://localhost:8000
FRONTEND_BASE_URL= # public URL of the frontend app for Stripe redirects (defaults to SERVER_BASE_URL)

# Stripe payments (optional — enables real card top-ups)
STRIPE_SECRET_KEY= # sk_live_... or sk_test_... from Stripe dashboard
STRIPE_WEBHOOK_SECRET= # whsec_... from Stripe dashboard > Webhooks (handles checkout.session.completed + account.updated)
STRIPE_PUBLISHABLE_KEY= # pk_live_... or pk_test_... (exposed to the frontend via /config/public)
TOPUP_DAILY_LIMIT_CENTS= # rolling 24h Stripe top-up cap per wallet, default: 100000 ($1,000.00); set 0 to disable
# Stripe Connect (agent withdrawals) uses the same STRIPE_SECRET_KEY — no extra keys needed.
# In the Stripe dashboard: enable Connect, add /stripe/webhook as a Connect webhook for "account.updated".

# Optional safety/feature toggles
ALLOW_PRIVATE_OUTBOUND_URLS= # allow private/localhost outbound agent URLs (0/1), default: 0
ADMIN_IP_ALLOWLIST= # optional admin CIDR/IP allowlist for /admin/* routes, e.g. 203.0.113.10,198.51.100.0/24
AGENTMARKET_ENABLE_LIVE_DISPUTE_JUDGES= # use Groq for dispute arbitration instead of fallback heuristics (0/1), default: 0
AGENTMARKET_ENABLE_LIVE_QUALITY_JUDGE= # use Groq for output quality judgment on completion (0/1), default: 0

# Jobs sweeper tuning
JOB_SWEEP_INTERVAL_SECONDS= # interval between sweep passes, default: 60
JOB_SWEEP_SLA_SECONDS= # age threshold for SLA timeout enforcement, default: 900
JOB_SWEEP_LIMIT= # max jobs processed per sweep category, default: 100
JOB_SWEEP_RETRY_DELAY_SECONDS= # retry delay for timeout-driven retries, default: 30

# Hook delivery worker tuning
HOOK_DELIVERY_INTERVAL_SECONDS= # poll interval for webhook delivery queue, default: 2
HOOK_DELIVERY_BATCH_SIZE= # deliveries claimed per worker pass, default: 50
HOOK_DELIVERY_MAX_ATTEMPTS= # max webhook retry attempts before dead-letter, default: 5
HOOK_DELIVERY_BASE_DELAY_SECONDS= # initial retry backoff for webhook failures, default: 5
HOOK_DELIVERY_MAX_DELAY_SECONDS= # max retry backoff for webhook failures, default: 300
HOOK_DELIVERY_CLAIM_LEASE_SECONDS= # lease duration when claiming delivery rows, default: 30

# Dispute and judge worker tuning
DISPUTE_FILE_WINDOW_SECONDS= # max age after completion to allow filing disputes, default: 604800
DEFAULT_JOB_DISPUTE_WINDOW_HOURS= # per-job dispute window when caller omits override, default: 72
DISPUTE_JUDGE_INTERVAL_SECONDS= # background arbitration loop interval (0 disables), default: 0

# Payments reconciliation worker tuning
PAYMENTS_RECONCILIATION_INTERVAL_SECONDS= # interval between automatic reconciliation runs (0 disables), default: 3600
PAYMENTS_RECONCILIATION_MAX_MISMATCHES= # max mismatches stored per reconciliation run, default: 100

# Built-in worker tuning
BUILTIN_JOB_WORKER_INTERVAL_SECONDS= # polling interval for built-in internal agents, default: 2
BUILTIN_JOB_WORKER_BATCH_SIZE= # batch size for built-in worker claims, default: 20

# SLO targets used by ops metrics endpoints
SLO_CLAIM_P95_TARGET_MS= # target p95 claim latency in milliseconds, default: 60000
SLO_SETTLEMENT_P95_TARGET_MS= # target p95 settlement latency in milliseconds, default: 300000
SLO_TIMEOUT_RATE_MAX= # target maximum timeout ratio, default: 0.05
SLO_HOOK_SUCCESS_RATE_MIN= # target minimum webhook success ratio, default: 0.95

# Optional MCP bridge script settings (scripts/agentmarket_mcp_server.py)
AGENTMARKET_BASE_URL= # registry API base URL for MCP bridge script, default: http://localhost:8000
AGENTMARKET_API_KEY= # API key used by MCP bridge script when invoking tools
AGENTMARKET_MCP_REFRESH_SECONDS= # MCP tool manifest refresh interval, default: 60
AGENTMARKET_MCP_TIMEOUT_SECONDS= # MCP HTTP timeout in seconds, default: 10
