# Dev-only dependencies layered on top of the prod pin set.
# `-r requirements.in` pulls in the prod loose pins so pip-compile resolves the
# full graph in one pass and emits requirements-dev.txt with consistent versions.
-r requirements.in
pytest
httpx
pytest-asyncio
flake8
