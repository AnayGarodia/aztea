[flake8]
max-line-length = 120
extend-ignore =
    # line length (handled by max-line-length)
    E501,
    # whitespace/alignment style
    E221, E231, E241,
    # continuation line indentation in deeply nested dict/list literals
    E122, E123, E124, E125, E126, E127, E128, E131,
    # inline comment spacing (single space before # in inline comments is fine)
    E261, E262,
    # blank line style
    E301, E302, E303, E304, E305, E306,
    # trailing whitespace / blank line at EOF
    W291, W292, W293, W391,
    # module level import not at top (needed after load_dotenv)
    E402,
    # do not require two blank lines in nested contexts
    E701, E711, E712,
    # whitespace before ':' (conflicts with Black-style slice formatting)
    E203,

# Per-file ignores for split packages that intentionally share a single logical
# namespace via their package __init__.py (or, for server.application, via the
# explicit part-loader). flake8 cannot reason across module boundaries, so it
# flags legitimate cross-part references as unused/undefined; tests exercise the
# merged surface and are the real source of truth.
per-file-ignores =
    # Application is sharded into ordered parts loaded into a single namespace
    # by server/application.py; imports and names are shared across parts.
    server/application_parts/*.py: F401, F403, F405, F811, F821
    server/application.py: F401
    # core.models is composed of peer files that star-import from core_types.
    core/models/__init__.py: F401, F403, F405
    core/models/core_types.py: F401, F403, F405, F811
    core/models/job_requests.py: F401, F403, F405, F811
    core/models/messages_ops.py: F401, F403, F405, F811
    core/models/responses.py: F401, F403, F405, F811
    # core.jobs package merges submodules into a single namespace in __init__.
    core/jobs/__init__.py: F401, F403
    core/jobs/crud.py: F401
    core/jobs/db.py: F401
    core/jobs/leases.py: F401
    core/jobs/messaging.py: F401, F811
    # core.payments / core.registry / core.auth package merging.
    core/payments/__init__.py: F401, F403
    core/payments/base.py: F401
    core/payments/trust_disputes.py: F401
    core/registry/__init__.py: F401, F403
    core/registry/agents_ops.py: F401
    core/registry/core_schema.py: F401
    core/auth/__init__.py: F401, F403
    core/auth/schema.py: F401
    core/auth/users.py: F401
    # Helper scripts: keep unused imports tolerated so generators stay readable.
    scripts/*.py: F401
    # Integration test modules `from tests.integration.support import *` so
    # helpers/constants/imports are shared; flake8 can't follow the star import.
    tests/integration/helpers.py: F401
    tests/integration/support.py: F401, F403
    tests/integration/test_*.py: F401, F403, F405
    # Pytest fixture imports show as unused to flake8 even though pytest uses
    # them via the fixture injection protocol. Tests also alias shared fixtures
    # as function parameters, which trips F811. These are not real issues.
    tests/*.py: F401, F811
    # SDK package ships its own test suite with the same pytest fixture pattern.
    sdks/python-sdk/tests/*.py: F401, F811
    sdks/python-sdk/tests/conftest.py: F401, F811

exclude =
    .git,
    __pycache__,
    node_modules,
    frontend,
    .release-venv,
    .venv,
    venv,
    build,
    dist,
    sdks/python-sdk/agentmarket/setup.py,
    sdks/python/,
    # quant-bench entries are test DATA, not source: they intentionally
    # mimic real-world AI-generated patches (one-line semicolons, occasional
    # unused imports left by the model). Linting them defeats the corpus's
    # purpose. The agent itself (agents/quant_patch_validator/) is still
    # linted normally.
    benchmarks/quant_bench/entries/,
    # Same logic for the publish-pipeline scammer corpus: each file is a
    # deliberate attack sample (intentional syntax errors, embedded fake
    # keys, prompt injection) that the listing-safety scanner must
    # reject. Linting them is meaningless and `syntax_error.py` would
    # fail any linter by design — that's the whole point.
    tests/security/corpus/scammer_listings/,
