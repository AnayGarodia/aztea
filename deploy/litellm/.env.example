# deploy/litellm/.env — secrets for the LiteLLM gateway compose stack.
# Copy to deploy/litellm/.env on the VM and fill in. NEVER commit the filled file.

# LiteLLM admin/master key (used to mint virtual keys + reach admin endpoints).
LITELLM_MASTER_KEY=sk-replace-with-a-long-random-secret

# Password for LiteLLM's dedicated Postgres (internal to the compose network).
LITELLM_DB_PASSWORD=replace-with-a-long-random-secret

# Azure upstreams that LiteLLM calls. These move OFF aztea's env and onto LiteLLM.
AZURE_RESPONSES_URL=https://your-azure-resource.services.ai.azure.com
AZURE_RESPONSES_KEY=your-azure-responses-key
AZURE_REALTIME_URL=wss://your-azure-resource.openai.azure.com/openai/v1/realtime
AZURE_REALTIME_KEY=your-azure-realtime-key
