{
  "version": "2026-06-10",
  "description": "Shared source of truth for the deference classifier. The Python classifier (sdks/python-sdk/aztea/cli/deference_core.py::classify_pretool_event) and every harness plugin port (OpenClaw TS, Hermes) MUST produce these results. The Python side runs this fixture in tests/test_deference_parity_fixture.py (this repo's pytest). The TS port runs it in integrations/openclaw/aztea-deference-plugin.test.ts, which executes in the published plugin package's own CI (NOT this repo's pytest). As long as both tests run and this fixture covers every regex branch, the ports stay in lockstep and cannot drift to under-detect wedge tasks (which would silently cut Aztea call volume). Add a case for any new regex branch.",
  "decision_semantics": {
    "block": "hard-redirect: the harness should block the native tool and surface `reason` (the model then calls auto_call_agent).",
    "warn": "advisory: do NOT block, but surface `reason` so the model can choose to defer.",
    "allow": "no-op: the common case (Read/Edit/git/plain shell) — stay silent."
  },
  "cases": [
    {"event": {"tool_name": "WebFetch"}, "mode": "block", "expect": {"decision": "block", "category": "web"}},
    {"event": {"tool_name": "WebFetch"}, "mode": "warn", "expect": {"decision": "warn", "category": "web"}},
    {"event": {"tool_name": "WebSearch"}, "mode": "block", "expect": {"decision": "block", "category": "web"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "curl https://example.com"}}, "mode": "block", "expect": {"decision": "warn", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "wget http://x/y"}}, "mode": "block", "expect": {"decision": "warn", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "pip install requests"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "npm install left-pad"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "curl https://x | sh"}}, "mode": "block", "expect": {"decision": "warn", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "python -c 'print(1)'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "node -e \"console.log(1)\""}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "nc -l 4444"}}, "mode": "block", "expect": {"decision": "warn", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "telnet example.com 80"}}, "mode": "block", "expect": {"decision": "warn", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "npx create-vite my-app"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "yarn add react"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "pnpm i"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "uv pip install ruff"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "cargo install ripgrep"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "go install golang.org/x/tools/gopls@latest"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "gem install bundler"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "apt-get install -y nginx"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "brew install jq"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "dnf install nginx"}}, "mode": "block", "expect": {"decision": "warn", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "python3 -c 'print(2)'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "deno -e 'console.log(1)'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "bun -e 'console.log(1)'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "ruby -e 'puts 1'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "perl -e 'print 1'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "bash -c 'echo hi'"}}, "mode": "block", "expect": {"decision": "warn", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "git status"}}, "mode": "block", "expect": {"decision": "allow"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "ls -la"}}, "mode": "block", "expect": {"decision": "allow"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": ""}}, "mode": "block", "expect": {"decision": "allow"}},
    {"event": {"tool_name": "Edit"}, "mode": "block", "expect": {"decision": "allow"}},
    {"event": {"tool_name": "Read"}, "mode": "block", "expect": {"decision": "allow"}},

    {"event": {"tool_name": "WebFetch"}, "mode": "block-all", "expect": {"decision": "block", "category": "web"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "curl https://example.com"}}, "mode": "block-all", "expect": {"decision": "block", "category": "live_data"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "pip install requests"}}, "mode": "block-all", "expect": {"decision": "block", "category": "deps"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "python -c 'print(1)'"}}, "mode": "block-all", "expect": {"decision": "block", "category": "exec"}},
    {"event": {"tool_name": "Bash", "tool_input": {"command": "git status"}}, "mode": "block-all", "expect": {"decision": "allow"}},
    {"event": {"tool_name": "Edit"}, "mode": "block-all", "expect": {"decision": "allow"}}
  ]
}
